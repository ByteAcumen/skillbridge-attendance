# Server
NODE_ENV=development
PORT=4000

# Database
# Neon production format:
# postgresql://user:password@host/database?sslmode=require
# Local Docker Compose format:
# postgresql://postgres:postgres@localhost:5432/skillbridge
DATABASE_URL="postgresql://user:password@host:5432/skillbridge?sslmode=require"

# Clerk Auth
# Required for backend JWT verification.
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# CORS
# Comma-separated list of allowed frontend origins.
FRONTEND_URL=http://localhost:3000

# Programme
PROGRAMME_TIME_ZONE=Asia/Kolkata

# Optional demo bootstrap for Docker/Railway.
# Set to true only when you want startup to create/update the five reviewer accounts.
SEED_DEMO_DATA=false

# Password used by accounts:seed. Defaults to SkillBridge@2026! when omitted.
TEST_ACCOUNT_PASSWORD=SkillBridge@2026!

# AI Insights
# Optional future LLM enhancement. Current insights work without this key.
GOOGLE_GENERATIVE_AI_API_KEY=
