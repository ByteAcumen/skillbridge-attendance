generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TRAINER
  INSTITUTION
  PROGRAMME_MANAGER
  MONITORING_OFFICER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  region    String?
  createdAt DateTime @default(now()) @map("created_at")

  users   User[]
  batches Batch[]

  @@map("institutions")
}

model User {
  id            String   @id @default(cuid())
  clerkUserId   String   @unique @map("clerk_user_id")
  name          String
  email         String?  @unique
  role          Role
  institutionId String?  @map("institution_id")
  createdAt     DateTime @default(now()) @map("created_at")

  institution       Institution?   @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  trainedBatches    BatchTrainer[]
  enrolledBatches   BatchStudent[]
  sessions          Session[]
  attendanceRecords Attendance[]
  createdInvites    BatchInvite[]

  @@map("users")
}

model Batch {
  id            String   @id @default(cuid())
  name          String
  institutionId String   @map("institution_id")
  createdAt     DateTime @default(now()) @map("created_at")

  institution Institution    @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  trainers    BatchTrainer[]
  students    BatchStudent[]
  sessions    Session[]
  invites     BatchInvite[]

  @@map("batches")
}

model BatchTrainer {
  batchId   String @map("batch_id")
  trainerId String @map("trainer_id")

  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  trainer User  @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@id([batchId, trainerId])
  @@map("batch_trainers")
}

model BatchStudent {
  batchId   String @map("batch_id")
  studentId String @map("student_id")

  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([batchId, studentId])
  @@map("batch_students")
}

model Session {
  id        String   @id @default(cuid())
  batchId   String   @map("batch_id")
  trainerId String   @map("trainer_id")
  title     String
  date      DateTime
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")

  batch      Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  trainer    User         @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  attendance Attendance[]

  @@map("sessions")
}

model Attendance {
  id        String           @id @default(cuid())
  sessionId String           @map("session_id")
  studentId String           @map("student_id")
  status    AttendanceStatus
  markedAt  DateTime         @default(now()) @map("marked_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@map("attendance")
}

model BatchInvite {
  id          String    @id @default(cuid())
  batchId     String    @map("batch_id")
  token       String    @unique
  reusable    Boolean   @default(true)
  maxUses     Int?      @map("max_uses")
  usesCount   Int       @default(0) @map("uses_count")
  expiresAt   DateTime? @map("expires_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  batch     Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("batch_invites")
}
